{
	"$schema": "node_modules/wrangler/config-schema.json",
	"name": "zeroeduform",
	"compatibility_date": "2025-04-04",
	"compatibility_flags": [
        "nodejs_compat"
    ],
	"main": "./workers/app.ts",
	"observability": {
		"enabled": true
	},
	"d1_databases": [
		{
			"binding": "DB",
			"database_name": "formzero",
			"database_id": "22257cf3-3144-4f42-ae73-02c16a63ce2c",
		}
	]
}